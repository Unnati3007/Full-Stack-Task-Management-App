# Copy this file to .env for local development.
# In production (Render), set these as environment variables in the dashboard instead.

# Postgres connection string.
# Local Docker:  postgresql://taskuser:taskpass@localhost:5432/taskdb
# Neon (hosted): postgresql://user:password@ep-xxxx.region.aws.neon.tech/taskdb?sslmode=require
DATABASE_URL=postgresql://taskuser:taskpass@localhost:5432/taskdb

# Set to "true" if DATABASE_URL doesn't already match a known hosted provider
# but still requires SSL (most managed Postgres do).
DATABASE_SSL=false

# Use long, random strings in production. Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string

PORT=5000

# The deployed frontend URL (Vercel), used for CORS.
# Local dev: http://localhost:5173 (Vite default port)
CLIENT_URL=http://localhost:5173
